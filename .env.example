# ─── Sibyl.ai Environment Variables ───
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# ─── Anthropic (LLM Reasoning) ───
ANTHROPIC_API_KEY=

# ─── Polymarket (READ-ONLY — US geo-restricted, data ingestion only) ───
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CHAIN_ID=137

# ─── Kalshi (PRIMARY EXECUTION PLATFORM) ───
# RSA key-pair authentication
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ─── Reddit (Breakout Scout) ───
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sibyl-bot/0.1

# ─── X / Twitter (Breakout Scout) ───
TWITTER_BEARER_TOKEN=

# ─── Perplexity (Breakout Scout) ───
PERPLEXITY_API_KEY=

# ─── Tavily (Breakout Scout — optional parallel web search) ───
# Optional: enables parallel Tavily web search alongside Perplexity Sonar.
# Get a free key at https://app.tavily.com (1,000 credits/month free).
TAVILY_API_KEY=

# ─── NewsAPI (Breakout Scout) ───
NEWSAPI_KEY=

# ─── Notifications ───
NTFY_TOPIC=sibyl-health
NTFY_SERVER=https://ntfy.sh

# ─── Database ───
DATABASE_PATH=data/sibyl.db
