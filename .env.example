# ─── Sibyl.ai Environment Variables ───
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# ─── Anthropic (LLM Reasoning) ───
ANTHROPIC_API_KEY=

# ─── Polymarket ───
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CHAIN_ID=137

# ─── Kalshi ───
KALSHI_API_KEY=
KALSHI_EMAIL=
KALSHI_PASSWORD=

# ─── Reddit (Breakout Scout) ───
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sibyl-bot/0.1

# ─── X / Twitter (Breakout Scout) ───
TWITTER_BEARER_TOKEN=

# ─── Perplexity (Breakout Scout) ───
PERPLEXITY_API_KEY=

# ─── NewsAPI (Breakout Scout) ───
NEWSAPI_KEY=

# ─── Notifications ───
NTFY_TOPIC=sibyl-health
NTFY_SERVER=https://ntfy.sh

# ─── Database ───
DATABASE_PATH=data/sibyl.db
